<Window
    x:Class="KompanionUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Kompanion"
    Icon="Assets/icon.ico"
    Width="700"
    Height="500"
    MinWidth="500"
    MinHeight="300"
    WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <SolidColorBrush x:Key="BrandBrush" Color="#FF009688"/>
        <SolidColorBrush x:Key="BrandDarkBrush" Color="#FF00695C"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFF2FAF8"/>
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="HeaderBgBrush" Color="#FFDDF3EE"/>
        <SolidColorBrush x:Key="BodyTextBrush" Color="#FF153532"/>

        <LinearGradientBrush x:Key="WindowBackground" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFF6FFFD" Offset="0"/>
            <GradientStop Color="#FFEAF7F3" Offset="0.58"/>
            <GradientStop Color="#FFDDF3EE" Offset="1"/>
        </LinearGradientBrush>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="14 6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource BodyTextBrush}"/>
        </Style>

        <Style x:Key="HeaderStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="6 5"/>
            <Setter Property="Foreground" Value="{StaticResource BodyTextBrush}"/>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Width" Value="70"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Margin" Value="3 2"/>
            <Setter Property="Padding" Value="4 2"/>
            <Setter Property="Background" Value="{StaticResource BrandBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrandDarkBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource BrandDarkBrush}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.55"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PanelCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="#FFC4E3DC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="8"/>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource WindowBackground}">
        <TabControl>
        <TabItem Header="Repositories">
            <Border Style="{StaticResource PanelCard}" Margin="2 0 2 2">
                <DockPanel>

                <ToolBar DockPanel.Dock="Top" Padding="4">
                    <Button x:Name="RefreshButton"
                            Click="RefreshButton_Click"
                            Width="80"
                            Padding="6 3"
                            Margin="0 0 6 0"
                            Background="{StaticResource BrandBrush}"
                            Foreground="White"
                            BorderBrush="{StaticResource BrandDarkBrush}"
                            ToolTip="Re-scan $env:KOMPANION_REPO">
                        Refresh
                    </Button>
                    <Button x:Name="CancelGitButton"
                            Click="CancelGitButton_Click"
                            Width="90"
                            Padding="6 3"
                            Margin="0 0 6 0"
                            Background="#FFB7472A"
                            Foreground="White"
                            BorderBrush="#FF8D3821"
                            ToolTip="Cancel current Git operation"
                            IsEnabled="False">
                        Cancel Git
                    </Button>
                    <Separator/>
                    <TextBlock x:Name="StatusText"
                               VerticalAlignment="Center"
                               Margin="6 0"
                               Foreground="{StaticResource BodyTextBrush}"
                               TextWrapping="NoWrap"/>
                </ToolBar>

                <Grid DockPanel.Dock="Top">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                        <Border Background="{StaticResource HeaderBgBrush}"
                            Grid.ColumnSpan="4"
                            BorderBrush="#FFC4E3DC"
                            BorderThickness="0 0 0 1"/>
                    <TextBlock Grid.Column="0" Text="Repository" Style="{StaticResource HeaderStyle}"/>
                    <TextBlock Grid.Column="1" Text="Launch" Style="{StaticResource HeaderStyle}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="Pull" Style="{StaticResource HeaderStyle}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="Push" Style="{StaticResource HeaderStyle}"
                               HorizontalAlignment="Center"/>
                </Grid>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="RepoList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.ColumnSpan="4"
                                            BorderBrush="#FFE3F1ED"
                                            BorderThickness="0 0 0 1"/>

                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Name}"
                                               VerticalAlignment="Center"
                                               Margin="8 4"
                                               Foreground="{StaticResource BodyTextBrush}"
                                               ToolTip="{Binding FullPath}"
                                               TextTrimming="CharacterEllipsis"/>

                                    <Button Grid.Column="1"
                                            Style="{StaticResource ActionButton}"
                                            Tag="{Binding FullPath}"
                                            Click="LaunchButton_Click"
                                            ToolTip="{Binding FullPath}">
                                        Launch
                                    </Button>

                                    <Button Grid.Column="2"
                                            Style="{StaticResource ActionButton}"
                                            Tag="{Binding FullPath}"
                                            Click="PullButton_Click"
                                            ToolTip="git pull">
                                        Pull
                                    </Button>

                                    <Button Grid.Column="3"
                                            Style="{StaticResource ActionButton}"
                                            Tag="{Binding FullPath}"
                                            Click="PushButton_Click"
                                            ToolTip="git push">
                                        Push
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                </DockPanel>
            </Border>
        </TabItem>

        <TabItem Header="Settings">
            <Border Style="{StaticResource PanelCard}" Margin="2 0 2 2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Margin="6"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource BrandDarkBrush}"
                               Text="Settings coming soon!"/>

                    <TextBlock Grid.Row="1"
                               Margin="6 0 6 10"
                               Foreground="{StaticResource BodyTextBrush}"
                               Text="Recent status and log-tail entries are shown below."/>

                    <TextBlock Grid.Row="2"
                               Margin="6 0 6 4"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BodyTextBrush}"
                               Text="Recent Activity"/>

                    <ListBox Grid.Row="3"
                             x:Name="HistoryList"
                             Margin="6"
                             BorderBrush="#FFC4E3DC"
                             Background="{StaticResource SurfaceBrush}"
                             Foreground="{StaticResource BodyTextBrush}"
                             FontFamily="Consolas"
                             FontSize="12"/>
                </Grid>
            </Border>
        </TabItem>
        </TabControl>
    </Grid>
</Window>
