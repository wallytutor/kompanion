<Window
    x:Class="KompanionUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:KompanionUI.Converters"
    Title="Kompanion"
    Icon="Assets/icon.ico"
    Width="700"
    Height="500"
    MinWidth="500"
    MinHeight="300"
    WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <local:HexColorToBrushConverter x:Key="HexColorToBrushConverter"/>
        <SolidColorBrush x:Key="BrandBrush" Color="#FF009688"/>
        <SolidColorBrush x:Key="BrandDarkBrush" Color="#FF00695C"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFF2FAF8"/>
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="HeaderBgBrush" Color="#FFDDF3EE"/>
        <SolidColorBrush x:Key="BodyTextBrush" Color="#FF153532"/>

        <LinearGradientBrush x:Key="WindowBackground" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFF6FFFD" Offset="0"/>
            <GradientStop Color="#FFEAF7F3" Offset="0.58"/>
            <GradientStop Color="#FFDDF3EE" Offset="1"/>
        </LinearGradientBrush>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="10"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="14 6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource BodyTextBrush}"/>
        </Style>

        <Style x:Key="HeaderStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="6 5"/>
            <Setter Property="Foreground" Value="{StaticResource BodyTextBrush}"/>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Width" Value="70"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Margin" Value="3 2"/>
            <Setter Property="Padding" Value="4 2"/>
            <Setter Property="Background" Value="{StaticResource BrandBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrandDarkBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource BrandDarkBrush}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.55"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PanelCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="#FFC4E3DC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="8"/>
        </Style>

        <Style x:Key="MutedLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF3D5E59"/>
            <Setter Property="Margin" Value="6 0 6 6"/>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource WindowBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0" Background="{StaticResource CardBrush}">
            <MenuItem Header="_File">
                <MenuItem Header="E_xit" Click="ExitMenuItem_Click"/>
            </MenuItem>
        </Menu>

        <TabControl Grid.Row="1">
        <TabItem Header="Repositories">
            <Border Style="{StaticResource PanelCard}" Margin="2 0 2 2">
                <DockPanel>

                <ToolBar DockPanel.Dock="Top" Padding="4">
                    <Button x:Name="RefreshButton"
                            Click="RefreshButton_Click"
                            Width="80"
                            Padding="6 3"
                            Margin="0 0 6 0"
                            Background="{StaticResource BrandBrush}"
                            Foreground="White"
                            BorderBrush="{StaticResource BrandDarkBrush}"
                            ToolTip="Re-scan $env:KOMPANION_REPO">
                        Refresh
                    </Button>
                    <Button x:Name="CheckAllButton"
                            Click="CheckAllButton_Click"
                            Width="90"
                            Padding="6 3"
                            Margin="0 0 6 0"
                            Background="{StaticResource BrandBrush}"
                            Foreground="White"
                            BorderBrush="{StaticResource BrandDarkBrush}"
                            ToolTip="Check status of all repositories">
                        Check All
                    </Button>
                    <Button x:Name="CancelGitButton"
                            Click="CancelGitButton_Click"
                            Width="90"
                            Padding="6 3"
                            Margin="0 0 6 0"
                            Background="#FFB7472A"
                            Foreground="White"
                            BorderBrush="#FF8D3821"
                            ToolTip="Cancel current Git operation"
                            IsEnabled="False">
                        Cancel Git
                    </Button>
                    <Separator/>
                    <TextBlock x:Name="StatusText"
                               VerticalAlignment="Center"
                               Margin="6 0"
                               Foreground="{StaticResource BodyTextBrush}"
                               TextWrapping="NoWrap"/>
                </ToolBar>

                <Grid DockPanel.Dock="Top">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                        <Border Background="{StaticResource HeaderBgBrush}"
                            Grid.ColumnSpan="5"
                            BorderBrush="#FFC4E3DC"
                            BorderThickness="0 0 0 1"/>
                    <TextBlock Grid.Column="0" Text="Repository" Style="{StaticResource HeaderStyle}"/>
                    <TextBlock Grid.Column="1" Text="Launch" Style="{StaticResource HeaderStyle}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="Pull" Style="{StaticResource HeaderStyle}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="Push" Style="{StaticResource HeaderStyle}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="4" Text="Status" Style="{StaticResource HeaderStyle}"
                               HorizontalAlignment="Center"/>
                </Grid>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="RepoList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.ColumnSpan="5"
                                            BorderBrush="#FFE3F1ED"
                                            BorderThickness="0 0 0 1"/>

                                    <TextBlock Grid.Column="0"
                                               VerticalAlignment="Center"
                                               Margin="8 4"
                                               Foreground="{StaticResource BodyTextBrush}"
                                               ToolTip="{Binding FullPath}">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="12"
                                                     Height="12"
                                                     Fill="{Binding StatusColor, Converter={StaticResource HexColorToBrushConverter}}"
                                                     VerticalAlignment="Center"
                                                     Margin="0 0 6 0"
                                                     ToolTip="Repository status"/>
                                            <TextBlock Text="{Binding Name}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </TextBlock>

                                    <Button Grid.Column="1"
                                            Style="{StaticResource ActionButton}"
                                            Tag="{Binding FullPath}"
                                            Click="LaunchButton_Click"
                                            ToolTip="{Binding FullPath}">
                                        Launch
                                    </Button>

                                    <Button Grid.Column="2"
                                            Style="{StaticResource ActionButton}"
                                            Tag="{Binding FullPath}"
                                            Click="PullButton_Click"
                                            ToolTip="git pull">
                                        Pull
                                    </Button>

                                    <Button Grid.Column="3"
                                            Style="{StaticResource ActionButton}"
                                            Tag="{Binding FullPath}"
                                            Click="PushButton_Click"
                                            ToolTip="git push">
                                        Push
                                    </Button>

                                    <Button Grid.Column="4"
                                            Style="{StaticResource ActionButton}"
                                            Tag="{Binding FullPath}"
                                            Click="StatusButton_Click"
                                            ToolTip="git status">
                                        Status
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                </DockPanel>
            </Border>
        </TabItem>

        <TabItem Header="Settings">
            <Border Style="{StaticResource PanelCard}" Margin="2 0 2 2">
                <StackPanel Margin="8">
                    <TextBlock Margin="0 0 0 10"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrandDarkBrush}"
                               Text="Behavior"/>

                    <CheckBox x:Name="MouseJigglingCheckBox"
                              Content="Enable mouse jiggling every 10 seconds"
                              IsChecked="True"
                              Margin="0 0 0 8"
                              Checked="MouseJigglingCheckBox_Changed"
                              Unchecked="MouseJigglingCheckBox_Changed"/>

                    <TextBlock Style="{StaticResource MutedLabel}"
                               Margin="0"
                               TextWrapping="Wrap"
                               Text="When enabled, Kompanion briefly moves the cursor and returns it to its original position to help prevent automatic screen lock while the app is running."/>
                </StackPanel>
            </Border>
        </TabItem>

        <TabItem Header="Ollama">
            <Border Style="{StaticResource PanelCard}" Margin="2 0 2 2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <ToolBar Grid.Row="0" Padding="4">
                        <Button x:Name="StartOllamaButton"
                                Width="100"
                                Height="26"
                                Margin="0 0 6 0"
                                Background="{StaticResource BrandBrush}"
                                Foreground="White"
                                BorderBrush="{StaticResource BrandDarkBrush}"
                                Click="StartOllamaButton_Click">
                            Start Server
                        </Button>
                        <Button x:Name="StopOllamaButton"
                                Width="100"
                                Height="26"
                                Margin="0 0 6 0"
                                Background="#FFB7472A"
                                Foreground="White"
                                BorderBrush="#FF8D3821"
                                Click="StopOllamaButton_Click">
                            Stop Server
                        </Button>
                        <Button x:Name="RefreshOllamaButton"
                                Width="80"
                                Height="26"
                                Margin="0 0 6 0"
                                Background="{StaticResource BrandBrush}"
                                Foreground="White"
                                BorderBrush="{StaticResource BrandDarkBrush}"
                                Click="RefreshOllamaButton_Click">
                            Refresh
                        </Button>
                        <Separator/>
                        <TextBlock x:Name="OllamaStatusText"
                                   VerticalAlignment="Center"
                                   Margin="6 0"
                                   Foreground="{StaticResource BodyTextBrush}"
                                   TextWrapping="Wrap"
                                   Text="Ollama status will appear here."/>
                    </ToolBar>

                    <TextBlock Grid.Row="1"
                               Margin="6 0 6 6"
                               Style="{StaticResource MutedLabel}"
                               Text="Running Ollama processes for OLLAMA_HOME executable."/>

                    <ListView Grid.Row="2"
                              x:Name="OllamaProcessesList"
                              Margin="6"
                              BorderBrush="#FFC4E3DC"
                              Background="{StaticResource SurfaceBrush}"
                              Foreground="{StaticResource BodyTextBrush}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="PID" Width="90"
                                                DisplayMemberBinding="{Binding Id}"/>
                                <GridViewColumn Header="Executable Path" Width="500"
                                                DisplayMemberBinding="{Binding Path}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>
        </TabItem>

        <TabItem Header="Applications">
            <Border Style="{StaticResource PanelCard}" Margin="2 0 2 2">
                <StackPanel Margin="8">
                    <!-- <TextBlock Style="{StaticResource MutedLabel}"
                               TextWrapping="Wrap"
                               Margin="0 0 0 12"
                               Text="Requires $env:LOGSEQ_HOME to be configured."/> -->
                    <Button x:Name="LaunchLogseqButton"
                            Width="130"
                            Height="30"
                            HorizontalAlignment="Left"
                            Padding="8 4"
                            Background="{StaticResource BrandBrush}"
                            Foreground="White"
                            BorderBrush="{StaticResource BrandDarkBrush}"
                            Cursor="Hand"
                            Click="LaunchLogseqButton_Click"
                            ToolTip="Launch Logseq — requires $env:LOGSEQ_HOME">
                        Launch Logseq
                    </Button>
                </StackPanel>
            </Border>
        </TabItem>

        <TabItem Header="Logs">
            <Border Style="{StaticResource PanelCard}" Margin="2 0 2 2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="4 2 4 8">
                        <TextBlock VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BodyTextBrush}"
                                   Text="Application Logs"/>
                        <Button x:Name="RefreshLogsButton"
                                DockPanel.Dock="Right"
                                Width="100"
                                Height="26"
                                Margin="8 0 0 0"
                                Click="RefreshLogsButton_Click"
                                Background="{StaticResource BrandBrush}"
                                Foreground="White"
                                BorderBrush="{StaticResource BrandDarkBrush}">
                            Refresh Logs
                        </Button>
                    </DockPanel>

                    <TextBlock Grid.Row="1"
                               x:Name="LogsHintText"
                               Style="{StaticResource MutedLabel}"
                               Text="Showing recent entries from kompanion-ui.log."/>

                    <ListView Grid.Row="2"
                              x:Name="LogsList"
                              Margin="6"
                              BorderBrush="#FFC4E3DC"
                              Background="{StaticResource SurfaceBrush}"
                              Foreground="{StaticResource BodyTextBrush}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Timestamp" Width="170"
                                                DisplayMemberBinding="{Binding Timestamp}"/>
                                <GridViewColumn Header="Message" Width="440"
                                                DisplayMemberBinding="{Binding Message}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>
        </TabItem>
        </TabControl>
    </Grid>
</Window>
