# Editor stuff
!.vscode/
.zed/

# Virtual environment and build directories
.venv/
venv/
_build/
_book/

# Python cache files
__pycache__/
*.pyc

# Jupyter Notebooks and checkpoints
*.ipynb_checkpoints/
*.ipynb

# Jupyter cache produced by jupyter-cache (Quarto)
*.jupyter_cache/

# Quarto defaults:
/.quarto/
**/*.quarto_ipynb

# Generated content:
_book/
*_files/
*.html
*.css
*.js
*.woff

# Temporaries generated by Quarto:
*.vdoc.*

# Any sandbox
*sandbox*

# Secrets
.env*

# Log files
*.log
log.*

# LaTeX
*.aux
*.fls
*.lof
*.lot
*.out
*.pdf
*.synctex*
*.toc
*.tex

# Containeirs
*.tar
*.sif
.tmp*.tar*